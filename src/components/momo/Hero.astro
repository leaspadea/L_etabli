---
import Container from "../layout/Container.astro";
---

<section class="hero">
  <Container>
    <div class="hero__grid">
      <div class="hero__intro">
        <h1 class="hero__title">
          Momo<span class="hero__surname">l'escargot.</span>
        </h1>

        <p class="section-subtitle">
          Manga, jeux vidéo, couleur. Travail soigné &amp; délicat.
        </p>

        <p class="hero__hand">je ne mords pas, juré</p>
      </div>

      <img
        class="hero__logo"
        src="/assets/logo_momo.png"
        alt="Logo de Momo l'escargot : un escargot en pixel art"
        loading="eager"
      />
    </div>
  </Container>
</section>

<style lang="scss">
  @use "../../styles/abstracts/breakpoints" as bp;
  @use "../../styles/abstracts/mixins" as *;

  .hero__grid {
        display: grid;
        margin-block: var(--s-6);
        gap: var(--s-6);
        border: 1px solid var(--color-gold-shadow);
        @include boiserie(10px, -8px);
        border: 6px solid transparent;
        border-image: linear-gradient(
                135deg,
                var(--color-gold-deep),
                var(--color-gold-bright),
                var(--color-gold),
                var(--color-gold-bright),
                var(--color-gold-deep)
            ) 1;
        padding: var(--s-6);
        @include bp.respond-to(desktop) {
            grid-template-columns: 1fr 1fr;
            gap: var(--s-8);
            align-items: center;
            padding: var(--s-8);
        }
    }

  .hero__surname {
    display: block;
    font-style: italic;
    color: var(--color-gray-muted);
  }

  .hero__hand {
    font-family: var(--f-hand);
    font-weight: 600;
    font-size: clamp(1.25rem, 4vw, 1.5rem);
    color: var(--color-momo-plum);
    transform: rotate(-2deg);
  }

  .hero__logo {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: contain;
  }

  .hero__title {
    padding-block: var(--s-5);
  }

  .hero__intro {
    gap: var(--s-2);
    display: flex;
    flex-direction: column;
  }
</style>
