---
import Container from "../layout/Container.astro";
---

<section class="hero">
  <Container>
    <div class="hero__frame">
      <h1>
        <img
          src="/assets/logo_letabli.png"
          alt="L'établi"
          width="943"
          height="594"
        />
      </h1>

      <p class="hero__tagline">Deux univers, un même atelier — Caen</p>
      <p class="hero__meta">Salon de tatouage · Caen, centre historique</p>
    </div>
  </Container>
</section>

<style lang="scss">
  @use "../../styles/abstracts/breakpoints" as bp;
  .hero {
    text-align: center;
    padding-block: var(--s-8);
    @include bp.respond-to(desktop) {
      padding-block: var(--s-9);
    }
  }

  .hero__frame {
    display: inline-block;
    background: var(--color-plaster-cream);
    padding: var(--s-5);
    border: 12px solid var(--color-gold);
    position: relative;

    box-shadow:
      inset 0 0 0 2px var(--color-gold-deep),
      0 0 0 2px var(--color-gold-shadow),
      0 14px 30px rgba(0, 0, 0, 0.5);
  }

  .hero__frame::before {
    content: "";
    position: absolute;
    inset: 10px;
    border: 1px solid var(--color-gold);
    pointer-events: none;
  }

  .hero__frame img {
    width: 100%;
    max-width: 300px;
    margin-inline: auto;
    @include bp.respond-to(desktop) {
      max-width: 700px;
    }
  }

  .hero__tagline {
    font-family: var(--f-display);
    font-style: italic;
    line-height: 1.3;
    text-wrap: balance;
    max-width: 760px;
    margin-inline: auto;
    margin-block: var(--s-3);
    font-size: 24px;
    color: var(--color-ink);
    @include bp.respond-to(desktop) {
      font-size: 36px;
      margin-block: var(--s-5);
    }
  }

  .hero__meta {
    margin-block: var(--s-3);
    font-family: var(--f-body);
    font-weight: 500;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    margin-inline: auto;
    color: var(--color-ink);
    display: flex;
    align-items: center;
    gap: var(--s-4);

    @include bp.respond-to(desktop) {
      font-size: 12px;
      margin-block: var(--s-5);
    }
  }

  .hero__meta::before,
  .hero__meta::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--color-gold);
  }
</style>
