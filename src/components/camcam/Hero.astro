---
import Container from "../layout/Container.astro";
---

<section class="hero">
    <Container>
        <div class="hero__grid">
            <img
                class="hero__portrait"
                src="/assets/photo_camcam.png"
                alt="Photo Camcam"
                loading="eager"
            />

            <div class="hero__intro">
                <h1>Camcam.</h1>
                <p class="section-subtitle">
                    Noir et gris · Brut, sombre, franc, précis.
                </p>
                <p class="hero__hand">Tatoueuse · depuis 2013</p>
            </div>
        </div>
    </Container>
</section>

<style lang="scss">
    @use "../../styles/abstracts/breakpoints" as bp;

    .hero__grid {
        display: grid;
        gap: var(--s-6);
        padding-block: var(--s-8);

        @include bp.respond-to(desktop) {
            grid-template-columns: 1fr 1fr;
            gap: var(--s-8);
            align-items: center;
        }
    }

    .hero__portrait {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: contain;
        filter: grayscale(1) contrast(1.1);
    }

    h1 {
        font-family: var(--f-display);
        font-weight: 500;
        line-height: 0.85;
        font-size: clamp(3.5rem, 12vw, 10.5rem);
    }


    .hero__intro {
        gap: var(--s-2);
        display: flex;
        flex-direction: column;
    }

    .hero__hand {
        font-family: var(--f-hand);
        font-weight: 600;
        font-size: clamp(1.25rem, 4vw, 1.5rem);
        color: var(--color-plaster-cream);
        transform: rotate(-2deg);
    }
</style>
